{{ 'section-hero-super-shine.css' | asset_url | stylesheet_tag }}

<section class="hero-banner" id="hero-banner-{{ section.id }}">

  <!-- ================= Desktop / Tablet ================= -->
  <div class="hero-banner__desktop">

    {% if section.settings.desktop_image != blank %}
      <img
        src="{{ section.settings.desktop_image | image_url: width: 1920 }}"
        srcset="
          {{ section.settings.desktop_image | image_url: width: 1920 }} 1x,
          {{ section.settings.desktop_image | image_url: width: 3840 }} 2x
        "
        alt="{{ section.settings.desktop_image.alt | escape }}"
        class="hero-banner__media"
        width="{{ section.settings.desktop_image.width }}"
        height="{{ section.settings.desktop_image.height }}"
        loading="eager"
      >
    {% else %}
      <div class="hero-banner__media hero-banner__media--placeholder">
        {{ 'hero-apparel-large' | placeholder_svg_tag }}
      </div>
    {% endif %}

    <div class="hero-banner__content container-site">

      {% if section.settings.eyebrow != blank %}
        <h3 class="hero-banner__eyebrow eyebrow text-gradient-brand font-bold">
        {{ section.settings.eyebrow }}
        </h3>
      {% endif %}

      <h2 class="hero-banner__heading">
        {{ section.settings.heading }}
        {% if section.settings.heading_highlight != blank %}
          <span class="text-gradient-brand">
            {{ section.settings.heading_highlight }}
          </span>
        {% endif %}
      </h2>

      {% if section.settings.button_label != blank %}
        <a
          href="{{ section.settings.button_link | default: '#' }}"
          class="hero-banner__btn btn btn-secondary"
        >
          {{ section.settings.button_label }}
        </a>
      {% endif %}

    </div>

  </div>

  <!-- ================= Mobile ================= -->

<div class="hero-banner__mobile">

  <div class="hero-banner__mobile-image-wrapper">

    {% if section.settings.mobile_image != blank %}
      <img
        src="{{ section.settings.mobile_image | image_url: width: 768 }}"
        alt="{{ section.settings.mobile_image.alt | escape }}"
        class="hero-banner__media"
        width="{{ section.settings.mobile_image.width }}"
        height="{{ section.settings.mobile_image.height }}"
        loading="eager"
      >
    {% elsif section.settings.desktop_image != blank %}
      <img
        src="{{ section.settings.desktop_image | image_url: width: 768 }}"
        alt="{{ section.settings.desktop_image.alt | escape }}"
        class="hero-banner__media"
        width="{{ section.settings.desktop_image.width }}"
        height="{{ section.settings.desktop_image.height }}"
        loading="eager"
      >
    {% endif %}

    <div class="hero-banner__mobile-content">

      {% if section.settings.eyebrow != blank %}
        <h3 class="hero-banner__eyebrow eyebrow text-gradient-brand font-bold">
        {{ section.settings.eyebrow }}
        </h3>
      {% endif %}

      <h2 class="hero-banner__heading">
        {{ section.settings.heading }}
        {% if section.settings.heading_highlight != blank %}
          <span class="text-gradient-brand">
            {{ section.settings.heading_highlight }}
          </span>
        {% endif %}
      </h2>

      {% if section.settings.button_label != blank %}
        <a
          href="{{ section.settings.button_link | default: '#' }}"
          class="btn btn-secondary hero-banner__btn"
        >
          {{ section.settings.button_label }}
        </a>
      {% endif %}

    </div>

  </div>

</div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "section-hero-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "new!"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "break up with basic dish soap. meet"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Gradient Heading",
      "default": "super shine."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "shop dish soap"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}