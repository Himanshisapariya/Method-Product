{%- comment -%}
  Section: Best Sellers Carousel ("go ahead, grab our fan favorites")
  Design system: method-design (Tailwind v4 tokens defined in css/application.css)
  Reference: methodproducts.com bestsellers carousel
{%- endcomment -%}

{% style %}
  #shopify-section-{{ section.id }} .bsc-track {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -ms-overflow-style: none;
    scrollbar-width: none;
    padding-bottom: 0.25rem;
  }
  #shopify-section-{{ section.id }} .bsc-track::-webkit-scrollbar {
    display: none;
  }
  #shopify-section-{{ section.id }} .bsc-card {
    scroll-snap-align: start;
    flex: 0 0 auto;
    width: 82%;
  }
  @media (min-width: 640px) {
    #shopify-section-{{ section.id }} .bsc-card { width: 46%; }
  }
  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} .bsc-card { width: calc(25% - 1.125rem); }
  }
  #shopify-section-{{ section.id }} .bsc-arrow {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 999px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-paper, #fff);
    border: 1px solid var(--color-border, #e6e6e6);
    color: var(--color-brand-purple, #7800bf);
    transition: opacity 0.15s ease, background 0.15s ease;
    cursor: pointer;
  }
  #shopify-section-{{ section.id }} .bsc-arrow:hover:not(:disabled) {
    background: var(--color-paper-alt, #fafafa);
  }
  #shopify-section-{{ section.id }} .bsc-arrow:disabled {
    color: var(--color-ink-soft, #707070);
    opacity: 0.45;
    cursor: default;
  }
  #shopify-section-{{ section.id }} .bsc-star svg {
    width: 0.9rem;
    height: 0.9rem;
  }
{% endstyle %}

<section
  id="shopify-section-{{ section.id }}"
  class="bsc py-12 md:py-16 relative bg-cover bg-center"
  style="{% if section.settings.background_image != blank %}background-image: url('{{ section.settings.background_image | image_url: width: 2400 }}');{% else %}background-color: var(--color-paper, #fff);{% endif %}"
>
  {%- if section.settings.background_image != blank and section.settings.overlay_opacity > 0 -%}
    <div class="absolute inset-0" style="background: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});"></div>
  {%- endif -%}
  <div class="container-md relative">

    {%- comment -%} Header row: eyebrow + heading on left, arrows on right {%- endcomment -%}
    <div class="flex items-end justify-between mb-8 md:mb-10">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="font-sans text-sm mb-2" style="color: {% if section.settings.light_text %}#ffffff{% else %}var(--color-ink-soft, #707070){% endif %};">
            {{ section.settings.eyebrow }}
          </p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="font-display font-bold text-[2rem] md:text-[2.5rem] lg:text-[2.75rem] leading-tight max-w-xl"
              style="color: {% if section.settings.light_text %}#ffffff{% else %}var(--color-ink, #414042){% endif %};">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}
      </div>

      <div class="hidden md:flex gap-3 shrink-0" data-bsc-nav>
        <button type="button" class="bsc-arrow" data-bsc-prev aria-label="Previous products">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
        </button>
        <button type="button" class="bsc-arrow" data-bsc-next aria-label="Next products">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </button>
      </div>
    </div>

    {%- comment -%} Card track {%- endcomment -%}
    <div class="bsc-track" data-bsc-track>
      {%- for block in section.blocks -%}
        {%- if block.type == 'product_card' -%}
          {%- assign s = block.settings -%}
          {%- assign p = s.product -%}
          <div class="bsc-card" {{ block.shopify_attributes }}>
            <div class="bg-white rounded-3xl overflow-hidden h-full flex flex-col">

              {%- comment -%} Product image {%- endcomment -%}
              <a href="{{ p.url | default: '#' }}" class="flex items-center justify-center px-8 pt-10 pb-6" style="min-height: 280px;">
                {%- if p != blank and p.featured_image != blank -%}
                  {{ p.featured_image | image_url: width: 500 | image_tag:
                      loading: 'lazy',
                      alt: p.featured_image.alt | default: p.title,
                      class: 'max-h-[220px] w-auto object-contain'
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'max-h-[220px] w-auto object-contain' }}
                {%- endif -%}
              </a>

              {%- comment -%} Content {%- endcomment -%}
              <div class="px-6 pb-6 flex flex-col flex-1">

                {%- comment -%} Rating (merchant-entered review count) {%- endcomment -%}
                {%- if s.rating_count != blank -%}
                  <div class="flex items-center gap-1 mb-3" style="color: var(--color-brand-purple, #7800bf);">
                    {%- for i in (1..5) -%}
                      <span class="bsc-star">
                        <svg viewBox="0 0 20 20" fill="currentColor"><path d="M10 1l2.6 5.7 6.2.6-4.7 4.2 1.4 6.2L10 14.8 4.5 17.7l1.4-6.2L1.2 7.3l6.2-.6L10 1z"/></svg>
                      </span>
                    {%- endfor -%}
                    <span class="font-sans text-sm ml-1" style="color: var(--color-ink-soft, #707070);">({{ s.rating_count }})</span>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: var(--color-ink-soft, #707070);">
                      <path d="M6 9l6 6 6-6"/>
                    </svg>
                  </div>
                {%- endif -%}

                {%- comment -%} Badge (merchant-entered tag) {%- endcomment -%}
                {%- if s.badge_style != 'none' and s.badge_text != blank -%}
                  <p class="font-display font-semibold text-sm mb-1"
                     style="color: {% if s.badge_style == 'new' %}var(--color-brand-purple, #7800bf){% else %}var(--color-brand-teal, #007a7d){% endif %};">
                    {{ s.badge_text }}
                  </p>
                {%- endif -%}

                {%- comment -%} Title — pulled from selected product {%- endcomment -%}
                {%- if p != blank -%}
                  <h3 class="font-sans text-base leading-snug mb-1" style="color: var(--color-ink, #414042);">
                    <a href="{{ p.url }}">{{ p.title }}</a>
                  </h3>
                {%- endif -%}

                {%- comment -%} Description (merchant-entered blurb, separate from product body) {%- endcomment -%}
                {%- if s.description != blank -%}
                  <p class="font-sans text-sm mb-2" style="color: var(--color-ink-soft, #707070);">
                    {{ s.description }}
                  </p>
                {%- endif -%}

                {%- comment -%} Price — pulled from selected product {%- endcomment -%}
                {%- if p != blank -%}
                  <p class="font-sans font-semibold text-base mb-4" style="color: var(--color-ink, #414042);">
                    {%- if p.price_varies -%}
                      {{ p.price_min | money }}+
                    {%- else -%}
                      {{ p.price | money }}
                    {%- endif -%}
                  </p>
                {%- endif -%}

                {%- comment -%} Add to cart — adds the selected product's default variant {%- endcomment -%}
                {%- if p != blank -%}
                  <product-form-mini class="mt-auto">
                    <form method="post" action="{{ routes.cart_add_url }}" data-bsc-add-form>
                      <input type="hidden" name="id" value="{{ p.selected_or_first_available_variant.id }}">
                      <input type="hidden" name="quantity" value="1">
                      <button
                        type="submit"
                        data-bsc-add-btn
                        {% unless p.available %}disabled{% endunless %}
                        class="w-full inline-flex items-center justify-center rounded-full font-display font-medium text-base py-3 border-2 transition-colors"
                        style="border-color: var(--color-brand-purple, #7800bf); color: {% if p.available %}var(--color-brand-purple, #7800bf){% else %}var(--color-ink-soft, #707070){% endif %}; background: transparent;"
                        onmouseover="if(!this.disabled){this.style.background='#F5DCFF'}" onmouseout="this.style.background='transparent'"
                      >
                        <span data-bsc-add-btn-text>{% if p.available %}add to cart{% else %}sold out{% endif %}</span>
                      </button>
                    </form>
                  </product-form-mini>
                {%- else -%}
                  <p class="mt-auto text-sm" style="color: var(--color-ink-soft, #707070);">select a product in the theme editor</p>
                {%- endif -%}

              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
  (function () {
    var section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;
    var track = section.querySelector('[data-bsc-track]');
    var prevBtn = section.querySelector('[data-bsc-prev]');
    var nextBtn = section.querySelector('[data-bsc-next]');
    if (!track || !prevBtn || !nextBtn) return;

    function scrollAmount() {
      var card = track.querySelector('.bsc-card');
      if (!card) return 300;
      var style = getComputedStyle(track);
      var gap = parseFloat(style.columnGap || style.gap || 24);
      return card.getBoundingClientRect().width + gap;
    }

    function updateArrows() {
      var maxScroll = track.scrollWidth - track.clientWidth - 2;
      prevBtn.disabled = track.scrollLeft <= 0;
      nextBtn.disabled = track.scrollLeft >= maxScroll;
    }

    prevBtn.addEventListener('click', function () {
      track.scrollBy({ left: -scrollAmount(), behavior: 'smooth' });
    });
    nextBtn.addEventListener('click', function () {
      track.scrollBy({ left: scrollAmount(), behavior: 'smooth' });
    });
    track.addEventListener('scroll', updateArrows);
    window.addEventListener('resize', updateArrows);
    updateArrows();

    {%- comment -%}
      Add to cart: intercepts the form submit and posts via AJAX so the
      page doesn't reload. Falls back to a normal form POST if fetch fails.
      Also refreshes the theme's cart icon bubble (Dawn's #cart-icon-bubble)
      if present, and dispatches a "cart:refresh" event other cart UI
      (e.g. a cart drawer) can listen for.
    {%- endcomment -%}
    var addForms = section.querySelectorAll('[data-bsc-add-form]');
    addForms.forEach(function (form) {
      form.addEventListener('submit', function (evt) {
        evt.preventDefault();
        var btn = form.querySelector('[data-bsc-add-btn]');
        var label = form.querySelector('[data-bsc-add-btn-text]');
        if (!btn || btn.disabled) return;

        var originalText = label ? label.textContent : '';
        btn.disabled = true;
        if (label) label.textContent = 'adding...';

        fetch('{{ routes.cart_add_url }}.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({
            id: form.querySelector('input[name="id"]').value,
            quantity: parseInt(form.querySelector('input[name="quantity"]').value, 10) || 1
          })
        })
          .then(function (res) {
            if (!res.ok) throw new Error('add to cart failed');
            return res.json();
          })
          .then(function () {
            if (label) label.textContent = 'added';
            document.dispatchEvent(new CustomEvent('cart:refresh'));

            var bubble = document.getElementById('cart-icon-bubble');
            if (bubble) {
              fetch('{{ routes.cart_url }}?section_id=cart-icon-bubble')
                .then(function (r) { return r.text(); })
                .then(function (html) {
                  var doc = new DOMParser().parseFromString(html, 'text/html');
                  var newBubble = doc.getElementById('cart-icon-bubble');
                  if (newBubble) bubble.innerHTML = newBubble.innerHTML;
                })
                .catch(function () {});
            }

            setTimeout(function () {
              if (label) label.textContent = originalText;
              btn.disabled = false;
            }, 1500);
          })
          .catch(function () {
            // Fallback: submit the form normally so the add still goes through.
            form.submit();
          });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Best sellers carousel",
  "tag": "section",
  "class": "section-best-sellers-carousel",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "shop bestsellers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "go ahead, grab our fan favorites"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Background image overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "light_text",
      "label": "Use white text for eyebrow/heading",
      "info": "Turn on when the background image is dark",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product",
          "info": "Image, title, price, and the add-to-cart action all come from this product."
        },
        {
          "type": "text",
          "id": "rating_count",
          "label": "Review count",
          "info": "Number shown in parentheses, e.g. 59",
          "default": "59"
        },
        {
          "type": "select",
          "id": "badge_style",
          "label": "Badge type",
          "options": [
            { "value": "best_seller", "label": "Best seller" },
            { "value": "new", "label": "New" },
            { "value": "none", "label": "None" }
          ],
          "default": "best_seller"
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge text",
          "default": "best seller"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Short description",
          "info": "Optional custom blurb shown under the product title (independent of the product's own description)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Best sellers carousel",
      "blocks": [
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}
