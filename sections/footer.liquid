{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

{%- style -%}
  /* ---- Method footer layout overrides ---- */

  .footer-method {
    background: var(--color-paper-alt, #fafafa);
    border-top: 1px solid var(--color-border, #e6e6e6);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    margin-top: {{ section.settings.margin_top }}px;
  }

  @media screen and (max-width: 749px) {
    .footer-method {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
      margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    }
  }

  /* 4-col grid */
  .footer-method__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media screen and (min-width: 768px) {
    .footer-method__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 3rem;
    }
  }

  @media screen and (min-width: 1024px) {
    .footer-method__grid {
      grid-template-columns: 200px 1fr 1fr 300px;
      gap: 4rem;
      align-items: start;
    }
  }

  /* Brand / logo col */
  .footer-method__brand-logo {
    display: block;
    margin-bottom: 1.25rem;
    width: 72px;
  }

  .footer-method__brand-logo img {
    width: 72px;
    height: auto;
    display: block;
    border-radius: 50%;
  }

  .footer-method__social-label {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-brand-purple, #7800bf);
    margin-bottom: 1rem;
  }

  /* Social icons override — dark fill */
  .footer-method .footer__list-social {
    justify-content: flex-start !important;
    gap: 0.75rem;
  }

  .footer-method .footer__list-social .list-social__link {
    color: var(--color-ink, #414042) !important;
    padding: 0 !important;
  }

  .footer-method .footer__list-social svg {
    fill: var(--color-ink, #414042) !important;
    width: 22px;
    height: 22px;
  }

  /* Menu column headings */
  .footer-method__col-heading {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-brand-purple, #7800bf);
    margin: 0 0 1.25rem 0;
  }

  /* Menu links */
  .footer-method__menu-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-method__menu-list li + li {
    margin-top: 0.6rem;
  }

  .footer-method__menu-list a {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-ink, #414042);
    text-decoration: none;
    line-height: 1.4;
    display: inline-block;
  }

  .footer-method__menu-list a:hover {
    color: var(--color-brand-purple, #7800bf);
  }

  /* Newsletter col */
  .footer-method__newsletter-desc {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-ink-soft, #707070);
    line-height: 1.5;
    margin-bottom: 1.25rem;
  }

  /* Newsletter form — override Dawn */
  .footer-method .footer__newsletter {
    margin: 0;
  }

  .footer-method .newsletter-form__field-wrapper {
    max-width: 100%;
  }

  .footer-method .field {
    display: flex;
    align-items: center;
    border: 1.5px solid var(--color-border, #e6e6e6);
    border-radius: 0.75rem;
    background: #fff;
    overflow: hidden;
    padding: 0;
  }

  .footer-method .field__input {
    flex: 1;
    border: none !important;
    outline: none !important;
    box-shadow: none !important;
    background: transparent;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-ink, #414042);
    padding: 0.75rem 1rem;
    min-height: unset;
    height: auto;
  }

  .footer-method .field__label {
    display: none;
  }

  .footer-method .newsletter-form__button {
    width: 36px;
    height: 36px;
    min-width: 36px;
    border-radius: 50%;
    background: var(--color-brand-purple, #7800bf);
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 0.35rem;
    cursor: pointer;
    flex-shrink: 0;
    padding: 0;
    transition: background 0.2s ease-out;
  }

  .footer-method .newsletter-form__button:hover {
    background: var(--color-brand-purple-deep, #4d0084);
  }

  .footer-method .newsletter-form__button svg,
  .footer-method .newsletter-form__button .svg-wrapper svg {
    fill: #fff !important;
    stroke: none !important;
    width: 16px;
    height: 16px;
  }

  .footer-method .newsletter-form__message {
    font-size: 0.8125rem;
    margin-top: 0.5rem;
  }

  /* Bottom bar */
  .footer-method__bottom {
    border-top: 1px solid var(--color-border, #e6e6e6);
    margin-top: 3rem;
    padding-top: 1.25rem;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
  }

  .footer-method__policies {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .footer-method__policies a {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-brand-purple, #7800bf);
    text-decoration: none;
  }

  .footer-method__policies a:hover {
    text-decoration: underline;
  }

  .footer-method__policies-sep {
    font-size: 0.8125rem;
    color: var(--color-ink-soft, #707070);
  }

  .footer-method__copyright {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-ink-soft, #707070);
  }
{%- endstyle -%}

{%- liquid
  assign has_social = false
  if settings.social_facebook_link != blank or settings.social_instagram_link != blank or settings.social_youtube_link != blank or settings.social_tiktok_link != blank or settings.social_twitter_link != blank or settings.social_pinterest_link != blank
    assign has_social = true
  endif

  assign menu_blocks = section.blocks | where: 'type', 'link_list'
-%}

<footer class="footer-method">
  <div class="container-md">

    <div class="footer-method__grid">

      {%- comment -%} Col 1: Brand logo + social {%- endcomment -%}
      <div>
        {%- if settings.brand_image != blank -%}
          <a href="{{ routes.root_url }}" class="footer-method__brand-logo">
            {{
              settings.brand_image
              | image_url: width: 144
              | image_tag:
                loading: 'lazy',
                widths: '72, 144',
                alt: shop.name
            }}
          </a>
        {%- else -%}
          <a href="{{ routes.root_url }}" class="footer-method__brand-logo" aria-label="{{ shop.name }}">
            {%- if settings.logo != blank -%}
              {{
                settings.logo
                | image_url: width: 144
                | image_tag:
                  loading: 'lazy',
                  widths: '72, 144',
                  alt: shop.name
              }}
            {%- endif -%}
          </a>
        {%- endif -%}

        {%- if has_social -%}
          <p class="footer-method__social-label">{{ section.settings.social_label }}</p>
          {%- render 'social-icons', class: 'footer__list-social' -%}
        {%- endif -%}
      </div>

      {%- comment -%} Col 2 + 3: Menu link_list blocks {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_list' -%}
          <div {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h3 class="footer-method__col-heading">{{ block.settings.heading }}</h3>
            {%- endif -%}
            {%- if block.settings.menu != blank -%}
              <ul class="footer-method__menu-list">
                {%- for link in block.settings.menu.links -%}
                  <li>
                    <a href="{{ link.url }}">{{ link.title | escape }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- comment -%} Col 4: Newsletter {%- endcomment -%}
      {%- if section.settings.newsletter_enable -%}
        <div>
          {%- if section.settings.newsletter_heading != blank -%}
            <h3 class="footer-method__col-heading">{{ section.settings.newsletter_heading }}</h3>
          {%- endif -%}
          {%- if section.settings.newsletter_subtext != blank -%}
            <p class="footer-method__newsletter-desc">{{ section.settings.newsletter_subtext }}</p>
          {%- endif -%}

          {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="newsletter-form__field-wrapper">
              <div class="field">
                <input
                  id="NewsletterForm--{{ section.id }}"
                  type="email"
                  name="contact[email]"
                  class="field__input"
                  value="{{ form.email }}"
                  aria-required="true"
                  autocorrect="off"
                  autocapitalize="off"
                  autocomplete="email"
                  {% if form.errors %}
                    autofocus
                    aria-invalid="true"
                    aria-describedby="ContactFooter-error"
                  {% elsif form.posted_successfully? %}
                    aria-describedby="ContactFooter-success"
                  {% endif %}
                  placeholder="{{ section.settings.newsletter_placeholder | default: 'email address' }}"
                  required
                >
                <label class="field__label" for="NewsletterForm--{{ section.id }}">
                  {{ 'newsletter.label' | t }}
                </label>
                <button
                  type="submit"
                  class="newsletter-form__button field__button"
                  name="commit"
                  id="Subscribe"
                  aria-label="{{ 'newsletter.button_label' | t }}"
                >
                  <span class="svg-wrapper">
                    {{- 'icon-arrow.svg' | inline_asset_content -}}
                  </span>
                </button>
              </div>

              {%- if form.errors -%}
                <small class="newsletter-form__message form__message" id="ContactFooter-error">
                  <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>
                  {{- form.errors.translated_fields.email | capitalize }}
                  {{ form.errors.messages.email -}}
                </small>
              {%- endif -%}
            </div>

            {%- if form.posted_successfully? -%}
              <h3
                class="newsletter-form__message newsletter-form__message--success form__message"
                id="ContactFooter-success"
                tabindex="-1"
                autofocus
              >
                <span class="svg-wrapper">{{- 'icon-success.svg' | inline_asset_content -}}</span>
                {{- 'newsletter.success' | t }}
              </h3>
            {%- endif -%}
          {%- endform -%}
        </div>
      {%- endif -%}

    </div>

    {%- comment -%} Bottom bar: policies + copyright {%- endcomment -%}
    <div class="footer-method__bottom">
      {%- if shop.policies.size > 0 -%}
        <div class="footer-method__policies">
          {%- for policy in shop.policies -%}
            {%- if policy != blank -%}
              {%- unless forloop.first -%}
                <span class="footer-method__policies-sep">|</span>
              {%- endunless -%}
              <a href="{{ policy.url }}">{{ policy.title | escape }}</a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
      <span class="footer-method__copyright">
        | &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}
      </span>
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "blocks": [
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "t:sections.footer.blocks.link_list.settings.heading.default",
          "label": "t:sections.footer.blocks.link_list.settings.heading.label"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Brand column"
    },
    {
      "type": "text",
      "id": "social_label",
      "label": "Social label",
      "default": "let's socialize"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__1.content",
      "info": "t:sections.footer.settings.header__1.info"
    },
    {
      "type": "checkbox",
      "id": "newsletter_enable",
      "default": true,
      "label": "t:sections.footer.settings.newsletter_enable.label"
    },
    {
      "type": "inline_richtext",
      "id": "newsletter_heading",
      "default": "refresh your inbox",
      "label": "t:sections.footer.settings.newsletter_heading.label"
    },
    {
      "type": "text",
      "id": "newsletter_subtext",
      "label": "Newsletter description",
      "default": "join our email list to get 10% off your first order, plus first dibs on exclusive offers + scent-illating news."
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Input placeholder",
      "default": "email address"
    },
    {
      "type": "header",
      "content": "t:sections.all.spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.footer.settings.margin_top.label",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "default": {
    "blocks": [
      { "type": "link_list" },
      { "type": "link_list" }
    ]
  }
}
{% endschema %}
