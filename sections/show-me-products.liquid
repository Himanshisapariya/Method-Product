{%- comment -%}
  Section: "Our fave raves" reviews carousel
  Design system: method-design (Tailwind v4 tokens in css/application.css)
  CSS: assets/section-show-me-products.css
  Features: review cards in a GPU-accelerated draggable carousel on a gradient bg
{%- endcomment -%}

{{ 'section-show-me-products.css' | asset_url | stylesheet_tag }}

<section
  id="shopify-section-{{ section.id }}"
  class="py-14 md:py-20 relative bg-cover bg-center"
  style="
    {%- if section.settings.background_image != blank -%}
      background-image: url('{{ section.settings.background_image | image_url: width: 2400 }}');
    {%- else -%}
      background: linear-gradient(to right, {{ section.settings.bg_start }}, {{ section.settings.bg_mid }}, {{ section.settings.bg_end }});
    {%- endif -%}
  "
>
  {%- if section.settings.background_image != blank and section.settings.overlay_opacity > 0 -%}
    <div
      class="absolute inset-0"
      style="background: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});"
    ></div>
  {%- endif -%}
  <div class="container-md relative">

    {%- comment -%} Centered header — white text {%- endcomment -%}
    <div class="text-center mb-10 md:mb-12">
      {%- if section.settings.eyebrow != blank -%}
        <p class="font-sans text-sm mb-3" style="color: rgba(255,255,255,0.85);">
          {{ section.settings.eyebrow }}
        </p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2
          class="font-display font-bold text-[2.25rem] md:text-[3rem] lg:text-[3.5rem] leading-tight"
          style="color: #fff;"
        >
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}
    </div>

    {%- comment -%} Carousel track {%- endcomment -%}
    <div class="smpt__track" data-smpt-track>
      {%- for block in section.blocks -%}
        {%- if block.type == 'review_card' -%}
          {%- assign s = block.settings -%}
          {%- assign p = s.product -%}
          <div class="smpt__card" {{ block.shopify_attributes }}>
            <div class="smpt__card-inner">

              {%- comment -%} Gradient image zone {%- endcomment -%}
              <a
                href="{{ p.url | default: s.button_link | default: '#' }}"
                class="smpt__image-wrap"
                tabindex="-1"
                aria-hidden="true"
              >
                {%- if p != blank and p.featured_image != blank -%}
                  {{ p.featured_image | image_url: width: 600 | image_tag:
                      loading: 'lazy',
                      alt: p.featured_image.alt | default: p.title,
                      class: 'smpt__image'
                  }}
                {%- elsif s.image != blank -%}
                  <img
                    src="{{ s.image | image_url: width: 600 }}"
                    alt="{{ s.image.alt | escape }}"
                    loading="lazy"
                    class="smpt__image"
                  >
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'smpt__image' }}
                {%- endif -%}
              </a>

              {%- comment -%} White content area {%- endcomment -%}
              <div class="smpt__card-body">

                <div class="smpt__stars" aria-label="5 stars">★★★★★</div>

                {%- if s.review_title != blank -%}
                  <p class="smpt__review-title">{{ s.review_title }}</p>
                {%- endif -%}

                {%- if s.review_quote != blank -%}
                  <p class="smpt__quote">{{ s.review_quote }}</p>
                {%- endif -%}

                <a
                  href="{{ p.url | default: s.button_link | default: '#' }}"
                  class="smpt__shop-btn"
                >
                  {{ s.button_label | default: 'shop now' }}
                </a>

              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%} Mobile nav arrows {%- endcomment -%}
    <div class="flex md:hidden items-center justify-center gap-4 mt-8">
      <button type="button" class="smpt__arrow" data-smpt-prev aria-label="Previous">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
      </button>
      <button type="button" class="smpt__arrow" data-smpt-next aria-label="Next">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 18l6-6-6-6"/>
        </svg>
      </button>
    </div>

  </div>
</section>

<script>
(function () {
  var sectionEl = document.getElementById('shopify-section-{{ section.id }}');
  if (!sectionEl) return;

  var track    = sectionEl.querySelector('[data-smpt-track]');
  var prevBtns = sectionEl.querySelectorAll('[data-smpt-prev]');
  var nextBtns = sectionEl.querySelectorAll('[data-smpt-next]');

  if (!track) return;

  // ---- Arrow scroll ----
  function scrollAmount() {
    var first = track.querySelector('.smpt__card');
    if (!first) return 300;
    var gap = parseFloat(getComputedStyle(track).columnGap || getComputedStyle(track).gap || 20);
    return first.getBoundingClientRect().width + gap;
  }

  function updateArrows() {
    var max = track.scrollWidth - track.clientWidth - 2;
    prevBtns.forEach(function (b) { b.disabled = track.scrollLeft <= 0; });
    nextBtns.forEach(function (b) { b.disabled = track.scrollLeft >= max; });
  }

  prevBtns.forEach(function (b) {
    b.addEventListener('click', function () {
      track.scrollBy({ left: -scrollAmount(), behavior: 'smooth' });
    });
  });

  nextBtns.forEach(function (b) {
    b.addEventListener('click', function () {
      track.scrollBy({ left: scrollAmount(), behavior: 'smooth' });
    });
  });

  track.addEventListener('scroll', updateArrows, { passive: true });
  window.addEventListener('resize', updateArrows);
  updateArrows();

  // ---- Drag-to-scroll (mouse) ----
  var dragging = false, dragStartX = 0, dragScrollStart = 0, dragMoved = false;

  track.addEventListener('mousedown', function (e) {
    dragging = true;
    dragMoved = false;
    dragStartX = e.pageX - track.offsetLeft;
    dragScrollStart = track.scrollLeft;
    track.style.scrollBehavior = 'auto';
  });

  document.addEventListener('mouseup', function () {
    dragging = false;
    track.style.scrollBehavior = 'smooth';
  });

  track.addEventListener('mousemove', function (e) {
    if (!dragging) return;
    e.preventDefault();
    dragMoved = true;
    track.scrollLeft = dragScrollStart - (e.pageX - track.offsetLeft - dragStartX);
  });

  track.addEventListener('click', function (e) {
    if (dragMoved) e.preventDefault();
  }, true);
})();
</script>

{% schema %}
{
  "name": "Fave raves carousel",
  "tag": "section",
  "class": "section-show-me-products",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "it seems our suds are something of a scent-sation"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "our fave raves"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "info": "When set, overrides the gradient below."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 30,
      "info": "Dark overlay on top of the background image."
    },
    {
      "type": "header",
      "content": "Background gradient (used when no image)"
    },
    {
      "type": "color",
      "id": "bg_start",
      "label": "Gradient start (left)",
      "default": "#d80e80"
    },
    {
      "type": "color",
      "id": "bg_mid",
      "label": "Gradient mid",
      "default": "#7800bf"
    },
    {
      "type": "color",
      "id": "bg_end",
      "label": "Gradient end (right)",
      "default": "#4d0084"
    }
  ],
  "blocks": [
    {
      "type": "review_card",
      "name": "Review card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product",
          "info": "Uses the product's image and URL. Leave blank to use the image and link fields below."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (fallback)",
          "info": "Used when no product is selected."
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Link (fallback)",
          "info": "Used when no product is selected."
        },
        {
          "type": "header",
          "content": "Review content"
        },
        {
          "type": "text",
          "id": "review_title",
          "label": "Review headline",
          "default": "so moisturized"
        },
        {
          "type": "textarea",
          "id": "review_quote",
          "label": "Quote",
          "default": "\"i love this product... it has never felt so healthy and nourished!\" -teef8"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "shop now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Fave raves carousel",
      "blocks": [
        {
          "type": "review_card",
          "settings": {
            "review_title": "so moisturized",
            "review_quote": "\"i love this shampoo!... my hair has never felt so healthy and nourished!\" -teef8",
            "button_label": "shop now"
          }
        },
        {
          "type": "review_card",
          "settings": {
            "review_title": "addictive",
            "review_quote": "\"leaves amazing results on the floor and the scent is addictive.\" -magical maids",
            "button_label": "shop now"
          }
        },
        {
          "type": "review_card",
          "settings": {
            "review_title": "my go-to",
            "review_quote": "\"this is my go to. it works well, i use it on everything and it smells so good!\" -lilheathz",
            "button_label": "shop now"
          }
        },
        {
          "type": "review_card",
          "settings": {
            "review_title": "amazing",
            "review_quote": "\"lathers well, smells amazing, scent actually lasts on the skin, moisturizes well\" -mickey",
            "button_label": "shop now"
          }
        }
      ]
    }
  ]
}
