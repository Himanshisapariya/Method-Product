{{ 'color-wheel-picker.js' | asset_url | script_tag }}

<section
  class="py-16 md:py-24 overflow-hidden"
  id="color-wheel-{{ section.id }}"
  data-section-id="{{ section.id }}"
>
  <div class="container-md">
    <div class="grid grid-cols-1 lg:grid-cols-[420px_1fr] gap-y-12 gap-x-16 items-center">

      <!-- LEFT: heading + wheel -->
      <div class="flex flex-col items-center text-center lg:items-start lg:text-left">
        {% if section.settings.heading != blank %}
          <h2 class="mb-3 max-w-[380px]">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p class="text-ink-soft text-lg mb-10">{{ section.settings.subheading }}</p>
        {% endif %}

        <!-- wheel -->
        <div
          class="relative w-[300px] h-[300px] sm:w-[340px] sm:h-[340px] lg:w-[380px] lg:h-[380px] rounded-full cursor-pointer touch-none shadow-[0_10px_40px_rgba(0,0,0,0.12)]"
          id="color-wheel-canvas-{{ section.id }}"
          data-color-wheel
          role="slider"
          aria-label="{{ section.settings.heading | default: 'color wheel' | escape }}"
          tabindex="0"
          style="background: conic-gradient(from 0deg, hsl(0,80%,55%), hsl(60,80%,55%), hsl(120,80%,55%), hsl(180,80%,55%), hsl(240,80%,55%), hsl(300,80%,55%), hsl(360,80%,55%));"
        >
          <!-- draggable handle -->
          <div
            class="absolute w-9 h-9 -ml-[18px] -mt-[18px] rounded-full bg-white border-[3px] border-brand-purple shadow-[0_2px_10px_rgba(0,0,0,0.25)] pointer-events-none transition-transform duration-75 ease-out"
            data-color-wheel-handle
            style="left: 50%; top: 82%;"
          ></div>
        </div>

        <!-- result label -->
        <div class="mt-8 min-h-[3.5rem]">
          <p class="text-ink text-lg">
            {{ section.settings.result_prefix | default: 'your happy place is:' }}
            <span class="font-display font-semibold text-brand-purple" data-color-wheel-label>
              {{ section.settings.default_label | default: 'live love lavender' }}
            </span>
          </p>
          {% if section.settings.footer_text != blank %}
            <p class="text-ink-soft text-sm mt-1">{{ section.settings.footer_text }}</p>
          {% endif %}
        </div>
      </div>

      <!-- RIGHT: product carousel -->
      <div class="relative">
        <!-- arrows -->
        <div class="hidden md:flex items-center gap-3 justify-end mb-6">
          <button
            type="button"
            class="w-11 h-11 flex items-center justify-center rounded-full border border-border text-brand-purple hover:bg-paper-alt transition-colors"
            data-color-wheel-prev
            aria-label="scroll left"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          </button>
          <button
            type="button"
            class="w-11 h-11 flex items-center justify-center rounded-full border border-border text-brand-purple hover:bg-paper-alt transition-colors"
            data-color-wheel-next
            aria-label="scroll right"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
        </div>

        <div
          class="flex gap-6 overflow-x-auto scroll-smooth snap-x snap-mandatory pb-4 [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]"
          data-color-wheel-track
        >
          {% liquid
            assign source = section.settings.product_source | default: 'manual'
          %}

          {% comment %} ---------- MANUAL MODE: hand-picked blocks ---------- {% endcomment %}
          {% if source == 'manual' %}
            {% for block in section.blocks %}
              {% if block.type == 'swatch' %}
                {% liquid
                  assign card_title = block.settings.custom_title
                  assign card_price = block.settings.custom_price
                  assign card_image = block.settings.custom_image
                  assign form_product = null
                  assign form_variant_id = null
                  if block.settings.product != blank
                    assign form_product = block.settings.product
                    assign card_title = form_product.title
                    assign card_price = form_product.price | money
                    assign card_image = form_product.featured_image
                    assign card_url = form_product.url
                    assign form_variant_id = form_product.selected_or_first_available_variant.id
                  else
                    assign card_url = block.settings.product_url
                  endif
                %}
                <div {{ block.shopify_attributes }}>
                  {% render 'color-wheel-card',
                    card_hue: block.settings.hue,
                    card_label: block.settings.swatch_label,
                    card_title: card_title,
                    card_price: card_price,
                    card_image: card_image,
                    card_url: card_url,
                    card_rating: block.settings.rating,
                    card_review_count: block.settings.review_count,
                    card_badge: block.settings.badge_text,
                    card_button_label: block.settings.button_label,
                    form_product: form_product,
                    form_variant_id: form_variant_id
                  %}
                </div>
              {% endif %}
            {% endfor %}

          {% comment %} ---------- COLLECTION MODE ---------- {% endcomment %}
          {% elsif section.settings.collection != blank %}
            {% liquid
              assign coll = collections[section.settings.collection]
              assign match_by = section.settings.match_by | default: 'tag'
              assign option_index = section.settings.variant_option_index | default: 1
            %}

            {% comment %} match_by = variant: one card per matching variant {% endcomment %}
            {% if match_by == 'variant' %}
              {% for product in coll.products %}
                {% for variant in product.variants %}
                  {% liquid
                    assign opt_value = ''
                    case option_index
                      when 1
                        assign opt_value = variant.option1
                      when 2
                        assign opt_value = variant.option2
                      when 3
                        assign opt_value = variant.option3
                    endcase
                    assign matched_hue = null
                    assign matched_label = null
                  %}
                  {% for block in section.blocks %}
                    {% if block.type == 'color_map' and block.settings.match_value != blank and opt_value != blank %}
                      {% assign mv = block.settings.match_value | downcase %}
                      {% assign ov = opt_value | downcase %}
                      {% if mv == ov %}
                        {% assign matched_hue = block.settings.hue %}
                        {% assign matched_label = block.settings.label | default: opt_value %}
                      {% endif %}
                    {% endif %}
                  {% endfor %}
                  {% if matched_hue != null %}
                    {% render 'color-wheel-card',
                      card_hue: matched_hue,
                      card_label: matched_label,
                      card_title: product.title,
                      card_price: variant.price | money,
                      card_image: variant.featured_image | default: product.featured_image,
                      card_url: product.url | append: '?variant=' | append: variant.id,
                      card_rating: section.settings.default_rating,
                      card_review_count: 0,
                      card_badge: section.settings.default_badge,
                      card_button_label: section.settings.default_button_label,
                      form_product: product,
                      form_variant_id: variant.id
                    %}
                  {% endif %}
                {% endfor %}
              {% endfor %}

            {% comment %} match_by = tag: one card per matching product {% endcomment %}
            {% else %}
              {% for product in coll.products %}
                {% liquid
                  assign matched_hue = null
                  assign matched_label = null
                %}
                {% for block in section.blocks %}
                  {% if block.type == 'color_map' and block.settings.match_value != blank %}
                    {% if product.tags contains block.settings.match_value %}
                      {% assign matched_hue = block.settings.hue %}
                      {% assign matched_label = block.settings.label | default: block.settings.match_value %}
                    {% endif %}
                  {% endif %}
                {% endfor %}
                {% if matched_hue != null %}
                  {% render 'color-wheel-card',
                    card_hue: matched_hue,
                    card_label: matched_label,
                    card_title: product.title,
                    card_price: product.price | money,
                    card_image: product.featured_image,
                    card_url: product.url,
                    card_rating: section.settings.default_rating,
                    card_review_count: 0,
                    card_badge: section.settings.default_badge,
                    card_button_label: section.settings.default_button_label,
                    form_product: product,
                    form_variant_id: product.selected_or_first_available_variant.id
                  %}
                {% endif %}
              {% endfor %}
            {% endif %}
          {% endif %}
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "color wheel picker",
  "tag": "section",
  "class": "section-color-wheel-picker",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "what color is your happy place?"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "find suds + sprays that match your style"
    },
    {
      "type": "text",
      "id": "result_prefix",
      "label": "Result prefix text",
      "default": "your happy place is:"
    },
    {
      "type": "text",
      "id": "default_label",
      "label": "Default color label (shown before user interacts)",
      "default": "live love lavender"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer helper text",
      "default": "tap the color wheel to change colors"
    },
    {
      "type": "header",
      "content": "Product source"
    },
    {
      "type": "select",
      "id": "product_source",
      "label": "Where do cards come from?",
      "options": [
        { "value": "manual", "label": "Manual — hand-picked swatch blocks" },
        { "value": "collection", "label": "Collection — auto-pull products from a collection" }
      ],
      "default": "manual"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to pull from",
      "info": "Only used when product source is set to Collection"
    },
    {
      "type": "select",
      "id": "match_by",
      "label": "Match products to wheel colors by",
      "options": [
        { "value": "tag", "label": "Product tag (one card per product)" },
        { "value": "variant", "label": "Variant option value (per variant)" }
      ],
      "default": "tag",
      "info": "Use 'Variant option value' if one product has multiple color/scent variants, e.g. a Scent option with values like 'french lavender'."
    },
    {
      "type": "select",
      "id": "variant_option_index",
      "label": "Variant option to match (Variant mode only)",
      "options": [
        { "value": "1", "label": "Option 1" },
        { "value": "2", "label": "Option 2" },
        { "value": "3", "label": "Option 3" }
      ],
      "default": "1",
      "info": "Whichever option position holds your color/scent name, e.g. Option 1 if 'Scent' is the first option on the product."
    },
    {
      "type": "range",
      "id": "default_rating",
      "label": "Default star rating shown on collection-mode cards",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "default": 5,
      "info": "Manual mode sets rating per block. Collection mode has no per-product rating field unless you wire in a review app."
    },
    {
      "type": "text",
      "id": "default_badge",
      "label": "Default badge text for collection-mode cards",
      "info": "Leave blank for no badge"
    },
    {
      "type": "text",
      "id": "default_button_label",
      "label": "Add to cart button label",
      "default": "add to cart"
    }
  ],
  "blocks": [
    {
      "type": "swatch",
      "name": "product swatch",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product",
          "info": "If set, title/price/image/cart come from this product. Leave blank to use custom fields below."
        },
        {
          "type": "text",
          "id": "swatch_label",
          "label": "Color / scent label",
          "info": "Shown as 'your happy place is: ___' when this swatch is selected",
          "default": "french lavender"
        },
        {
          "type": "range",
          "id": "hue",
          "label": "Wheel position (hue)",
          "min": 0,
          "max": 360,
          "step": 5,
          "default": 280,
          "info": "Position on the color wheel, 0-360°, that this product is matched to"
        },
        {
          "type": "header",
          "content": "Custom fallback (used only if no product selected)"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "custom_price",
          "label": "Price"
        },
        {
          "type": "url",
          "id": "product_url",
          "label": "Link"
        },
        {
          "type": "header",
          "content": "Card details"
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge text",
          "info": "e.g. refill + reuse"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 0,
          "max": 5,
          "step": 0.5,
          "default": 5
        },
        {
          "type": "number",
          "id": "review_count",
          "label": "Review count",
          "default": 0
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "add to cart"
        }
      ]
    },
    {
      "type": "color_map",
      "name": "color mapping",
      "settings": [
        {
          "type": "text",
          "id": "match_value",
          "label": "Tag or variant option value to match",
          "info": "In Tag mode: an exact product tag, e.g. 'color:lavender'. In Variant mode: the exact option value, e.g. 'french lavender'. Matching is case-insensitive."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Display label",
          "info": "Shown as 'your happy place is: ___'. Leave blank to reuse the matched value."
        },
        {
          "type": "range",
          "id": "hue",
          "label": "Wheel position (hue)",
          "min": 0,
          "max": 360,
          "step": 5,
          "default": 280
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "color wheel picker",
      "blocks": [
        { "type": "swatch" },
        { "type": "swatch" },
        { "type": "swatch" },
        { "type": "swatch" }
      ]
    }
  ]
}
{% endschema %}
